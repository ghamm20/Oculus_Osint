# PostgreSQL connection string.
# For local dev: The platform will automatically spin up PostgreSQL via Docker Compose.
# Set DATABASE_URL to: postgresql://postgres:postgres@localhost:5432/worldwideview?schema=public
#
# For cloud/production: Provide your external Postgres connection string (e.g. Supabase)
# and set WWV_SKIP_LOCAL_DB=true to prevent Docker from spinning up a local database instance.
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/worldwideview?schema=public

# Set this to true in production to prevent docker-compose or pnpm run dev from starting the local database.
# WWV_SKIP_LOCAL_DB=false

# Local Ollama assistant
LOCAL_LLM_BASE_URL=http://127.0.0.1:11434
LOCAL_LLM_MODEL=llama3.2

# Optional key-gated DOT camera feeds
WSDOT_API_KEY=
OHGO_API_KEY=
FL511_API_KEY=

# Satellite feeds from CelesTrak GP data
SATELLITE_FEED_GROUPS=stations,weather,resource,science,geo,gps-ops,galileo,beidou,visual,intelsat,ses,iridium-NEXT,oneweb
SATELLITE_FEED_LIMIT=2200

# Optional authorized Citizen/incident export
CITIZEN_API_URL=
CITIZEN_API_BASE_URL=
CITIZEN_API_INCIDENTS_PATH=/incidents
CITIZEN_API_KEY=
CITIZEN_FEED_FILE=

# Default plugins enabled on boot for demo edition
# Comma-separated list of plugin IDs
NEXT_PUBLIC_DEMO_DEFAULT_PLUGINS=sample-intelligence

# Edition: "local" | "cloud" | "demo"
NEXT_PUBLIC_WWV_EDITION=local

# Auth Secret (REQUIRED for Docker — generate with: openssl rand -hex 32)
# Must be stable across container restarts to preserve sessions.
# [WARNING] NEVER commit real secrets here. Real secrets must ONLY go into .env.local!
AUTH_SECRET=changeme
 
 
